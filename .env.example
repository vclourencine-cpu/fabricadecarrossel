# ================================================================
# Carousel SaaS — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ================================================================

# ── Supabase (obrigatório) ───────────────────────────────────────
# Encontre em: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua-service-role-key

# ── Admin (obrigatório) ──────────────────────────────────────────
# Email do único usuário autorizado a fazer login
ADMIN_EMAIL=vclourencine@gmail.com

# ── Anthropic / Claude (para Modo IA) ────────────────────────────
# Opcional — necessário apenas para o modo "Gerar com IA"
# Obtenha em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...sua-chave
